# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Atlas:      mongodb+srv://username:password@cluster.xxxxx.mongodb.net/edupay
MONGO_URI=

# ─── Redis ───────────────────────────────────────────────────────────────────
# Local:      redis://localhost:6379
# Redis Cloud: redis://default:password@host:port
REDIS_URL=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Nomba API ───────────────────────────────────────────────────────────────
NOMBA_BASE_URL=https://api.nomba.com/v1

# Use TEST credentials during development, swap to LIVE before final demo
NOMBA_CLIENT_ID=
NOMBA_SECRET_KEY=

# Account IDs — from your hackathon welcome email
NOMBA_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the value set in Railway/your hosting platform
NOMBA_WEBHOOK_SECRET=